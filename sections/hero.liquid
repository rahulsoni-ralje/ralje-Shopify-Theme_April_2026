{% comment %}
  RALJE — Hero Section
  Full-viewport cinematic entry with image or video background.
{% endcomment %}

<section class="hero" id="hero">

  <div class="hero__media">
    {% if section.settings.video != blank %}
      <video autoplay muted loop playsinline>
        <source src="{{ section.settings.video }}" type="video/mp4">
      </video>
    {% elsif section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 1920 | image_tag: loading: 'eager' }}
    {% endif %}
    <div class="hero__overlay"></div>
  </div>

  <div class="hero__content">
    <h1 class="hero__title reveal">{{ section.settings.heading | default: 'RALJE' }}</h1>
    <p class="hero__subtitle reveal">{{ section.settings.subtitle | default: 'A private atelier. By consultation only.' }}</p>
    {% if section.settings.cta_text != blank %}
      <a href="{{ section.settings.cta_link | default: '/pages/commission' }}" class="atelier-btn atelier-btn--bordered reveal">
        {{ section.settings.cta_text }}
      </a>
    {% endif %}
  </div>

  <div class="hero__scroll reveal">Descend</div>

</section>

{% schema %}
{
  "name": "Hero — Cinematic Entry",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "video",
      "label": "Background Video URL (MP4)",
      "info": "Upload an MP4 to Files, copy the URL, and paste here."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "RALJE"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "A private atelier. By consultation only."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Commission a Consultation"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link",
      "default": "/pages/commission"
    }
  ],
  "presets": [
    {
      "name": "Hero — Cinematic Entry"
    }
  ]
}
{% endschema %}
